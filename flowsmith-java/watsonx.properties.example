# Copy this file to  watsonx.properties  (same folder) and fill in your values.
# watsonx.properties is git-ignored - real credentials are never committed.
#
# Get these from IBM Cloud / watsonx.ai:
#   url        - the watsonx.ai region endpoint
#   apikey     - IBM Cloud API key (IAM)
#   projectId  - your watsonx.ai project id
#   modelId    - a Granite (or other) foundation model id

watsonx.url = https://us-south.ml.cloud.ibm.com
watsonx.apikey = YOUR_IBM_CLOUD_API_KEY
watsonx.projectId = YOUR_WATSONX_PROJECT_ID
watsonx.modelId = ibm/granite-3-8b-instruct

# Alternatively, set these as environment variables (they override the file):
#   WATSONX_URL  WATSONX_APIKEY  WATSONX_PROJECT_ID  WATSONX_MODEL_ID
