<?xml version="1.0" encoding="UTF-8"?>
<!--
  Rule 1 — Naming conventions.
  Derived from Existing_Templates/ and flowsmith/catalog.json. Bob must apply these
  when instantiating any pattern. Placeholders SUBSYS/APPNM/FUNCNM/NDMNM are replaced
  with the developer-supplied tokens; the literal suffix FIL and the TYPE segment stay.
-->
<rule id="naming-conventions" appliesTo="flowsmith-ace-developer">

  <tokens>
    <token name="SUBSYS" required="true"  transform="uppercase" example="XAJ"/>
    <token name="APPNM"  required="true"  transform="asis"      example="TLMTF"/>
    <token name="FUNCNM" required="true"  transform="asis"      example="FINANCING"/>
    <token name="NDMNM"  required="false" transform="asis"      example="REFPGN"/>
    <token name="TYPE"   required="true"  values="PTP,PUB,SUB"  note="determined by the chosen pattern"/>
  </tokens>

  <conventions>
    <project name="application">
      <pattern>&lt;SUBSYS&gt;_&lt;TYPE&gt;_&lt;APPNM&gt;_&lt;FUNCNM&gt;_FIL</pattern>
      <example>XAJ_SUB_TLMTF_FINANCING_FIL</example>
    </project>
    <project name="config">
      <pattern>&lt;SUBSYS&gt;_&lt;TYPE&gt;_&lt;APPNM&gt;_&lt;FUNCNM&gt;_FIL_Configs</pattern>
      <example>XAJ_SUB_TLMTF_FINANCING_FIL_Configs</example>
    </project>
    <folderPath>
      <pattern>&lt;TYPE&gt;/&lt;SUBSYS&gt;/&lt;APPNM&gt;/&lt;FUNCNM&gt;/FIL/</pattern>
      <note>The source tree mirrors the schema namespace exactly.</note>
    </folderPath>
    <brokerSchema>
      <pattern>&lt;TYPE&gt;.&lt;SUBSYS&gt;.&lt;APPNM&gt;.&lt;FUNCNM&gt;.FIL</pattern>
      <note>Must match the folder path, dot-separated. Appears at the top of every ESQL file.</note>
    </brokerSchema>
    <propFile>
      <pattern>&lt;TYPE&gt;_&lt;SUBSYS&gt;_&lt;APPNM&gt;_&lt;FUNCNM&gt;.prop</pattern>
      <location>&lt;configProject&gt;/batchconfig/{DEV,ACC,PRO}/</location>
    </propFile>
  </conventions>

  <enforcement>
    <check>Every occurrence of SUBSYS/APPNM/FUNCNM/NDMNM in folder names, .project &lt;name&gt;,
           BROKER SCHEMA, ESQL, .msgflow and .prop files is replaced consistently.</check>
    <check>SUBSYS is uppercased; the FIL suffix and TYPE segment are never altered.</check>
    <check>No placeholder token strings (SUBSYS/APPNM/FUNCNM/NDMNM) remain in the output.</check>
  </enforcement>
</rule>
