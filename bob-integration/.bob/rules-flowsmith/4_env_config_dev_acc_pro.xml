<?xml version="1.0" encoding="UTF-8"?>
<!--
  Rule 4 — Multi-environment configuration (DEV / ACC / PRO).
  Every application ships one .prop file per environment under
  <configProject>/batchconfig/{DEV,ACC,PRO}/. Keys are taken from the reference
  templates' .prop files. Only environment-specific values differ between DEV/ACC/PRO.
-->
<rule id="env-config-dev-acc-pro" appliesTo="flowsmith-ace-developer">

  <environments>
    <environment>DEV</environment>
    <environment>ACC</environment>
    <environment>PRO</environment>
  </environments>

  <propFile name="&lt;TYPE&gt;_&lt;SUBSYS&gt;_&lt;APPNM&gt;_&lt;FUNCNM&gt;.prop">
    <key name="RUNTIME.LOCATION" example="/mgmt/etc/esb/XXX/SUBSYS/"/>
    <key name="FLOW.DESCRIPTION" example="Batch PTP"/>
    <key name="FLOW.MODE" values="PTP,PUB,SUB" note="matches the pattern TYPE"/>
    <key name="INPUT.FILE"  example=".*\.xml"/>
    <key name="INPUT.DIR"   example="/mgmt/data/esb/XXX/FUNCNM/pub/SUBSYS/APPNM/"/>
    <key name="OUTPUT.FILE" example=".*\.cbl"/>
    <key name="OUTPUT.DIR"  example="/mgmt/data/esb/XXX/FUNCNM/sub/SUBSYS/APPNM/"/>
    <key name="INPUT.FILE.CHECK"  example="NO"/>
    <key name="OUTPUT.FILE.CHECK" example="NO"/>
  </propFile>

  <enforcement>
    <check>All three of DEV, ACC, PRO .prop files are generated with tokens substituted.</check>
    <check>FLOW.MODE equals the pattern TYPE (PTP/PUB/SUB).</check>
    <check>Paths embed SUBSYS/APPNM/FUNCNM consistently; the XXX site placeholder is set
           per the target environment's standard, not left literal if a value is known.</check>
    <check>Environment-specific values (endpoints, queues, security) live here, never in ESQL.</check>
  </enforcement>
</rule>
